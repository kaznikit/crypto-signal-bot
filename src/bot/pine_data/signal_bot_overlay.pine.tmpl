//@version=5
indicator("Signal Bot Signals", overlay=true, max_labels_count=500)

var int[]    sig_t       = array.new_int(0)
var int[]    sig_t2      = array.new_int(0)
var float[]  sig_price   = array.new_float(0)
var string[] sig_kind    = array.new_string(0)
var string[] sig_subkind = array.new_string(0)
var string[] sig_dir     = array.new_string(0)
var float[]  sig_ote_lo  = array.new_float(0)
var float[]  sig_ote_hi  = array.new_float(0)
var float[]  sig_sl      = array.new_float(0)
var float[]  sig_tp      = array.new_float(0)
var int[]    sig_imp_start_t     = array.new_int(0)
var int[]    sig_imp_end_t       = array.new_int(0)
var float[]  sig_imp_start_price = array.new_float(0)
var float[]  sig_imp_end_price   = array.new_float(0)

if barstate.isfirst
{{PUSH_BLOCK}}

if barstate.islast
    n = array.size(sig_t)
    n := math.min(n, array.size(sig_price))
    n := math.min(n, array.size(sig_kind))
    n := math.min(n, array.size(sig_dir))
    n := math.min(n, array.size(sig_imp_start_t))
    n := math.min(n, array.size(sig_imp_end_t))
    n := math.min(n, array.size(sig_imp_start_price))
    n := math.min(n, array.size(sig_imp_end_price))
    last_i = n > 0 ? n - 1 : na
    for i = 0 to last_i
        t_ms = array.get(sig_t, i)
        k = array.get(sig_kind, i)
        d = array.get(sig_dir, i)
        p = array.get(sig_price, i)
        imp_start_t = array.get(sig_imp_start_t, i)
        imp_end_t = array.get(sig_imp_end_t, i)
        imp_start_p = array.get(sig_imp_start_price, i)
        imp_end_p = array.get(sig_imp_end_price, i)

        entry_style = d == "LONG" ? label.style_label_up : label.style_label_down
        exit_style = d == "LONG" ? label.style_label_down : label.style_label_up
        signal_color = d == "LONG" ? color.teal : color.orange

        if k == "PREPARE"
            label.new(
                 t_ms,
                 p,
                 text="PREPARE " + d,
                 xloc=xloc.bar_time,
                 style=entry_style,
                 color=color.new(signal_color, 0),
                 textcolor=color.white,
                 size=size.small)
            if imp_start_t > 0 and not na(imp_start_p)
                label.new(
                     imp_start_t,
                     imp_start_p,
                     text="IMP START",
                     xloc=xloc.bar_time,
                     style=entry_style,
                     color=color.new(color.gray, 30),
                     textcolor=color.white,
                     size=size.tiny)
            if imp_end_t > 0 and not na(imp_end_p)
                label.new(
                     imp_end_t,
                     imp_end_p,
                     text="IMP END",
                     xloc=xloc.bar_time,
                     style=exit_style,
                     color=color.new(signal_color, 35),
                     textcolor=color.white,
                     size=size.tiny)
        else if k == "ENTRY"
            label.new(
                 t_ms,
                 p,
                 text="ENTRY " + d,
                 xloc=xloc.bar_time,
                 style=entry_style,
                 color=color.new(color.blue, 0),
                 textcolor=color.white,
                 size=size.small)
        else if k == "TAKE_PROFIT"
            label.new(
                 t_ms,
                 p,
                 text="TP " + d,
                 xloc=xloc.bar_time,
                 style=exit_style,
                 color=color.new(color.green, 0),
                 textcolor=color.white,
                 size=size.small)
        else if k == "STOP_LOSS"
            label.new(
                 t_ms,
                 p,
                 text="SL " + d,
                 xloc=xloc.bar_time,
                 style=entry_style,
                 color=color.new(color.red, 0),
                 textcolor=color.white,
                 size=size.small)
